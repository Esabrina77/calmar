<Window x:Class="FenetreWait"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:my="clr-namespace:Calmar"
    Title="Calmar"
    Width="140" Height="80"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStyle="None"
    Topmost="True">

    <Grid Background="#FFDFE9F5">
        <Border CornerRadius="5" BorderThickness="1" BorderBrush="Black">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <TextBlock Name="TextBlockWait" Text="Waiting" TextAlignment="Center" VerticalAlignment="Center" />
                <ProgressBar Grid.Row="2" IsIndeterminate="True" Value="100" Height="10" Width="100" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>
