<Window x:Class="FenetreInput"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Calmar"
    Width="Auto" Height="Auto" SizeToContent="WidthAndHeight"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStyle="ToolWindow">

    <Border Background="#FFDFE9F5">
        <Grid Margin="10,2,10,5">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition Height="25" />
            </Grid.RowDefinitions>

            <!-- CADRES DU MESSAGE -->
            <Image Name="IconeSystem" Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,-8,0" />
            
            <TextBlock Grid.Row="0" Name="TextBlockMessage" TextWrapping="Wrap" VerticalAlignment="Center" Margin="2" />
            <TextBox Grid.Row="1" Name="TextBlockRetourMessage" TextWrapping="Wrap" VerticalAlignment="Center" Margin="2" />

            <!-- GESTION DES BOUTONS -->
            <Button Grid.Row="2" Content="OK" Width="75" Margin="0,0,79,0" HorizontalAlignment="Right" Click="RetourOK" />
            <Button Grid.Row="2" Content="Cancel" Width="75" Margin="0,0,2,0" HorizontalAlignment="Right" Click="RetourCancel"  />
        </Grid>
    </Border>
</Window>
