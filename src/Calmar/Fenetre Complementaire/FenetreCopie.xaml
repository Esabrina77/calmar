<Window x:Class="FenetreCopie"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            Title="Calmar" Height="300" Width="500"
            ResizeMode="NoResize"
	        WindowStartupLocation="CenterScreen"
            WindowState="Normal"
	        Background="#FFDFE9F5"
            ShowInTaskbar="False">

    <Grid x:Name="LayoutRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="20" />
            <RowDefinition />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="75" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3" BorderThickness="1" BorderBrush="Black" />
        <Border Grid.Row="1" Grid.ColumnSpan="3" BorderThickness="1" BorderBrush="Black" />
        <Border Grid.RowSpan="2" Grid.Column="1" BorderThickness="1" BorderBrush="Black" />

        <TextBlock Grid.Row="0" Grid.Column="0" Name="TextBlockNameBuoyCopy" HorizontalAlignment="Center" VerticalAlignment="Center" />
        <TextBlock Grid.Row="0" Grid.Column="1" Name="MainButtonCopierBouee" Text="Copier" HorizontalAlignment="Center" VerticalAlignment="Center" />
        <TextBlock Grid.Row="0" Grid.Column="2" Name="TextBlockNameBuoyPaste" HorizontalAlignment="Center" VerticalAlignment="Center" />

        <Border Grid.Row="1" Grid.Column="0" Name="BuoyCopy" />
        <Border Grid.Row="1" Grid.Column="2" Name="BuoyPaste" />

        <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" >
            <TextBlock Grid.Row="0" Grid.Column="1" Text=">>" HorizontalAlignment="Center" VerticalAlignment="Center" />
            <Button Content="Structure" Name="ManagerBuoyStructureTab" Margin="5" Click="CopyStructure_Click" />
            <Button Content="Flotteur" Name="ManagerBuoyFlotteurTab" Margin="5" Click="CopyFlotteur_Click" />
            <Button Content="Pylone" Name="ManagerBuoyPyloneTab" Margin="5" Click="CopyPylone_Click" />
            <Button Content="Voyant" Name="ManagerBuoyVoyantTab" Margin="5" Click="CopyVoyant_Click" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text=">>" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </StackPanel>
       
        <Button Grid.Row="2" Grid.ColumnSpan="3" Content="Ok" Name="EquipButtonValidationEquipement" VerticalAlignment="Center" HorizontalAlignment="Right" Width="100" Margin="0,0,5,0" Click="EquipButtonValidationEquipement_Click" />
    </Grid>
</Window>
