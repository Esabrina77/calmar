<Window x:Class="FenetreParametreSite"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Calmar"
    Width="300" Height="200"
    ResizeMode="CanMinimize"
    WindowStartupLocation="CenterScreen"
    ShowInTaskbar="False"
    Background="#FFDFE9F5" WindowStyle="ToolWindow">

    <Grid Name="LayoutRoot">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <!-- Grid parametre site -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.4*" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Name="FenetreParametreSiteTextBlockLatitude" Text="Latitude" VerticalAlignment="Center" Margin="2" />
            <TextBlock Grid.Row="1" Name="FenetreParametreSiteTextBlockLongitude" Text="Longitude" VerticalAlignment="Center" Margin="2" />
            <TextBlock Grid.Row="2" Name="FenetreParametreSiteTextBlockDensité" Text="Densité de l'eau" VerticalAlignment="Center" Margin="2" TextWrapping="Wrap" />
            <TextBlock Grid.Row="3" Name="FenetreParametreSiteTextBlockTrainee" Text="Coefficient de trainée" VerticalAlignment="Center" Margin="2" TextWrapping="Wrap" />
            
            <TextBox Grid.Row="0" Grid.Column="1" Name="FenetreParametreSiteTextBoxLatitude" TextChanged="FenetreParametreSiteTextBoxLatitude_TextChanged" Text="0.0000" Margin="2" />
            <TextBox Grid.Row="1" Grid.Column="1" Name="FenetreParametreSiteTextBoxLongitude" TextChanged="FenetreParametreSiteTextBoxLongitude_TextChanged" Text="0.0000" Margin="2" />

            <Grid Grid.Row="2" Grid.Column="1" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.65*" />
                    <ColumnDefinition Width="0.45*" />
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" Name="FenetreParametreSiteComboBoxDensiteEau" SelectionChanged="FenetreParametreSiteComboBoxDensiteEau_SelectionChanged"  Margin="2">
                    "Eau salée"
                    "Eau douce"
                    "Autre"
                </ComboBox>
                <TextBox Grid.Column="1" Name="FenetreParametreSiteTextBoxDensiteEau" TextChanged="FenetreParametreSiteTextBoxDensiteEau_TextChanged" Text="0.0000" Margin="2" />
            </Grid>

            <Grid Grid.Row="3" Grid.Column="1" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.65*" />
                    <ColumnDefinition Width="0.45*" />
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" Name="FenetreParametreSiteComboBoxTrainee" SelectionChanged="FenetreParametreSiteComboBoxTrainee_SelectionChanged" Margin="2">
                    "Salissure forte = 1.4"
                    "Normal = 1.2"
			        "Salissure faible = 0.9"
			        "Eau douce bouée neuve sans salissure = 0.6"
                </ComboBox>
                <TextBox Grid.Column="1" Name="FenetreParametreSiteTextBoxTrainee" IsReadOnly="True" Text="0.0000" Margin="2" />
            </Grid>

        </Grid>

        <Button Grid.Row="2" Content="Ok" Name="ButtonValidationSite" VerticalAlignment="Center" HorizontalAlignment="Right" Width="100" Margin="0,0,5,0" Click="ButtonValidationSite_Click" />
    </Grid>
</Window>
