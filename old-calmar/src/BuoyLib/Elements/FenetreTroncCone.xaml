<controls:ChildWindow x:Class="SilverlightBuoyLib.FenetreTroncCone"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
           xmlns:controls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls"
           Width="400" Height="250"
           Title="FenetreTroncCone" HasCloseButton="False">
    
    <Grid x:Name="LayoutRoot" Margin="2">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="35" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="100" />
        </Grid.ColumnDefinitions>


        <Border Grid.Row="0" Margin="5" Height="150" BorderBrush="Black" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition />
                    <RowDefinition Height="40" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="75" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" Width="100">
                    <TextBlock Text="Diametre haut" TextAlignment="Center"></TextBlock>
                    <TextBox Name="DiametreHaut" TextAlignment="Center"></TextBox>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Hauteur" TextAlignment="Center"></TextBlock>
                    <TextBox Name="Hauteur" TextAlignment="Center"></TextBox>
                </StackPanel>
                <Border Grid.Row="1" Grid.Column="1" Name="DrawCanvas">
                </Border>
                <StackPanel Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center" Width="100">
                    <TextBlock Text="Diametre bas" TextAlignment="Center"></TextBlock>
                    <TextBox Name="DiametreBas" TextAlignment="Center"></TextBox>
                </StackPanel>

            </Grid>
        </Border>
        <Border Grid.Row="0" Grid.Column="1" Margin="5" Height="150" BorderBrush="Black" BorderThickness="1">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Diametre int." TextAlignment="Center"></TextBlock>
                <TextBox Name="DiametreInt" TextAlignment="Center"></TextBox>
                <Border Height="10" />
                <TextBlock Text="Volume" TextAlignment="Center"></TextBlock>
                <TextBox Name="Volume" TextAlignment="Center"></TextBox>
            </StackPanel>
        </Border>

        <Button x:Name="CancelButton" Content="Annuler" Width="75" Height="23" HorizontalAlignment="Right" Margin="0,12,0,0" Grid.Row="1" Grid.ColumnSpan="2" />
        <Button x:Name="OKButton" Content="OK" Width="75" Height="23" HorizontalAlignment="Right"  Margin="0,12,79,0" Grid.Row="1" Grid.ColumnSpan="2" />
    </Grid>
</controls:ChildWindow>
