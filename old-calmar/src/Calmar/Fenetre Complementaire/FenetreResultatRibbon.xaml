<Window x:Class="FenetreResultatRibbon"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:chartingToolkit="clr-namespace:System.Windows.Controls.DataVisualization.Charting;assembly=System.Windows.Controls.DataVisualization.Toolkit"
	Title="Calmar"
	Width="850" Height="600"
	ResizeMode="CanMinimize"
	WindowStartupLocation="CenterScreen"
    WindowState="Normal"
	Background="#FFDFE9F5"
    ShowInTaskbar="False">

	<Grid Name="LayoutRoot">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition />
		</Grid.RowDefinitions>

        <Ribbon Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Margin="0,-20,0,0" Name="MenuRibbonResultat"
                       ContextMenuOpening="MenuRibbon_ContextMenuOpening"
                       SizeChanged="MenuRibbon_SizeChanged"
                       MouseDoubleClick="MenuRibbon_MouseDoubleClick">
			<Ribbon.ApplicationMenu>
				<RibbonApplicationMenu Visibility="Collapsed" >
				</RibbonApplicationMenu>
			</Ribbon.ApplicationMenu>

            <RibbonTab Name="ResultRibbonTabComparateur" Header="Comparateur">
                <RibbonGroup Name="ResultRibbonGroupBuoy" Header="Bouée">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition />
							<RowDefinition />
						</Grid.RowDefinitions>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="55" />
							<ColumnDefinition />
						</Grid.ColumnDefinitions>

                        <TextBlock Margin="0,5,0,5" Grid.Row="0" Grid.Column="0" Name="ResultTextBlockBouee1" Text="Bouée 1" Foreground="Blue" VerticalAlignment="Center" />
                        <TextBlock Margin="0,5,0,5" Grid.Row="1" Grid.Column="0" Name="ResultTextBlockBouee2" Text="Bouée 2" Foreground="Green" VerticalAlignment="Center" />

						<ComboBox Margin="1,5,0,5" Grid.Row="0" Grid.Column="1" Name="BoueeComparateur1" Foreground="Blue" SelectionChanged="BoueeComparateur1_SelectionChanged" />
                        <ComboBox Margin="1,5,0,5" Grid.Row="1" Grid.Column="1" Name="BoueeComparateur2" Foreground="Green" SelectionChanged="BoueeComparateur2_SelectionChanged" />
						
					</Grid>
				</RibbonGroup>

                <RibbonGroup  Name="ResultRibbonGroupChaine" Header="Chaines">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <TextBlock Margin="5,5,0,5" Grid.Row="0" Grid.Column="0"  Name="ResultTextBlockDN1" Text="DN" Foreground="Blue" VerticalAlignment="Center" />
                        <TextBlock Margin="5,5,0,5" Grid.Row="1" Grid.Column="0"  Name="ResultTextBlockDN2" Text="DN" Foreground="Green" VerticalAlignment="Center" />

                        <ComboBox Margin="1,5,1,5" Grid.Row="0" Grid.Column="1" Name="ChaineDNComparateur1" Foreground="Blue" SelectionChanged="ChaineDNComparateur1_SelectionChanged" />
                        <ComboBox Margin="1,5,1,5" Grid.Row="1" Grid.Column="1" Name="ChaineDNComparateur2" Foreground="Green" SelectionChanged="ChaineDNComparateur2_SelectionChanged" />

                        <TextBlock Margin="0,5,0,5" Grid.Row="0" Grid.Column="2"  Name="ResultTextBlockType1" Text="Type" Foreground="Blue" VerticalAlignment="Center" />
                        <TextBlock Margin="0,5,0,5" Grid.Row="1" Grid.Column="2"  Name="ResultTextBlockType2" Text="Type" Foreground="Green" VerticalAlignment="Center" />

                        <ComboBox Margin="1,5,1,5" Grid.Row="0" Grid.Column="3" Name="ChaineTypeComparateur1" Foreground="Blue" SelectionChanged="ChaineTypeComparateur1_SelectionChanged" />
                        <ComboBox Margin="1,5,1,5" Grid.Row="1" Grid.Column="3" Name="ChaineTypeComparateur2" Foreground="Green" SelectionChanged="ChaineTypeComparateur2_SelectionChanged" />

                        <TextBlock Margin="0,5,0,5" Grid.Row="0" Grid.Column="4"  Name="ResultTextBlockQualite1" Text="Qualité" Foreground="Blue" VerticalAlignment="Center" />
                        <TextBlock Margin="0,5,0,5" Grid.Row="1" Grid.Column="4"  Name="ResultTextBlockQualite2" Text="Qualité" Foreground="Green" VerticalAlignment="Center" />

                        <ComboBox Margin="1,5,5,5" Grid.Row="0" Grid.Column="5" Name="ChaineQualiteComparateur1" Foreground="Blue" SelectionChanged="ChaineQualiteComparateur1_SelectionChanged">
							<ComboBoxItem>1</ComboBoxItem>
							<ComboBoxItem>2</ComboBoxItem>
							<ComboBoxItem>3</ComboBoxItem>
						</ComboBox>
                        <ComboBox Margin="1,5,5,5" Grid.Row="1" Grid.Column="5" Name="ChaineQualiteComparateur2" Foreground="Green" SelectionChanged="ChaineQualiteComparateur2_SelectionChanged">
							<ComboBoxItem>1</ComboBoxItem>
							<ComboBoxItem>2</ComboBoxItem>
							<ComboBoxItem>3</ComboBoxItem>
						</ComboBox>

                    </Grid>
				</RibbonGroup>

                <RibbonGroup Name="ResultRibbonGroupLest" Header="Lest">
                    <Grid Width="100">
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="20" />
                        </Grid.ColumnDefinitions>

                        <ComboBox Margin="0,5,0,5" Grid.Row="0" Name="ComboBoxLestComparateur1" Foreground="Blue" SelectionChanged="ComboBoxLestComparateur1_SelectionChanged" />
                        <Button Margin="0,5,0,5" Grid.Row="0" Grid.Column="1" Width="18" Height="18" Name="ButtonLestComparateur1" Click="ButtonLestComparateur1_Click">
                            <Image Source="/Calmar;component/Images/ko.png" />
                        </Button>
                        <ComboBox Margin="0,5,0,5" Grid.Row="1" Name="ComboBoxLestComparateur2" Foreground="Green" SelectionChanged="ComboBoxLestComparateur2_SelectionChanged" />
                        <Button Margin="0,5,0,5" Grid.Row="1" Grid.Column="1" Width="18" Height="18" Name="ButtonLestComparateur2" Click="ButtonLestComparateur2_Click">
                            <Image Source="/Calmar;component/Images/ko.png" />
                        </Button>
                    </Grid>
                </RibbonGroup>

                <RibbonGroup Name="ResultRibbonGroupDensiteCM" Header="Densité du corps mort">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition />
							<RowDefinition />
						</Grid.RowDefinitions>

                        <ComboBox Margin="0,5,0,5" Grid.Row="0" Name="ResultComboBoxDensiteCM1" Foreground="Blue" SelectionChanged="ComboBoxDensiteCM1_SelectionChanged">
							"2.4 (Béton Armé Norme Std)"
							"2.8 (Béton Armé Chargé)"
							"3.0 (Béton Armé Hématite)"
							"7.3 (Fonte d'Acier)"
							"7.85 (Acier)"
						</ComboBox>

                        <ComboBox Margin="0,5,0,5" Grid.Row="1" Name="ResultComboBoxDensiteCM2" Foreground="Green" SelectionChanged="ComboBoxDensiteCM2_SelectionChanged">
                            "2.4 (Béton Armé Norme Std)"
							"2.8 (Béton Armé Chargé)"
							"3.0 (Béton Armé Hématite)"
							"7.3 (Fonte d'Acier)"
							"7.85 (Acier)"
                        </ComboBox>

                    </Grid>

                </RibbonGroup>

                <RibbonGroup Name="ResultRibbonGroupPlus" Header="Plus">
                    <RibbonButton Name="ButtonSpecial"
										 LargeImageSource="..\Images\32\application.png"
										 Label="Plus" Click="SpecialResult_Click" />
                </RibbonGroup>
                
			</RibbonTab>

            <RibbonTab Name="ResultRibbonTabPrintExport" Header="Impression et Export">

                <RibbonGroup Name="ResultRibbonGroupTitleProject" Header="Titre du document">
                    <Grid Width="180" Height="70">
                        <TextBox Name="TextBoxProjectName" TextAlignment="Center" VerticalAlignment="Center" TextChanged="TextBoxProjectName_TextChanged" />
                    </Grid>
                </RibbonGroup>

                <RibbonGroup Name="ResultRibbonGroupPrint" Header="Impression">
                    <RibbonButton Name="ResultButtonImpression"
										 Margin="10,0,10,0"
										 LargeImageSource="..\Images\32\printer.png"
										 Label="Impression" Click="PrintButton_Click" />
				</RibbonGroup>

                <RibbonGroup Name="ResultRibbonGroupExport" Header="Export">
                    <RibbonButton Name="ResultButtonExportCSV"
										 Margin="10,0,10,0"
										 LargeImageSource="..\Images\32\export_excel.png"
										 Label="Txt" Click="ExportButton_Click" />
				</RibbonGroup>
			</RibbonTab>

            <RibbonTab Name="ResultRibbonTabView" Header="Visualisation">

                <RibbonGroup Name="ResultRibbonGroupView" Header="Visualisation">
                    <RibbonButton Name="ResultButtonVisualisation"
										 Margin="10,0,10,0"
										 LargeImageSource="..\Images\32\voir.png"
										 Label="Visualisation à pic" Click="ResultButtonVisualisation_Click" />
                </RibbonGroup>
                
            </RibbonTab>
        </Ribbon>

		<Grid Grid.Row="1">
			<Grid.RowDefinitions>
				<RowDefinition Height="105" />
				<RowDefinition />
			</Grid.RowDefinitions>

			<Border Grid.Row="0" BorderThickness="1" CornerRadius="5,5,0,0" BorderBrush="Black">
				<Grid>
					<Grid.RowDefinitions>
                        <RowDefinition Height="17" />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition Height="20" />
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="80" />
						<ColumnDefinition Width="1" />
                        <ColumnDefinition />
						<ColumnDefinition />
						<ColumnDefinition />
						<ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Name="ResultTextBlockDN" Text="DN" TextAlignment="Center" />
					<TextBox Grid.Row="1" Grid.Column="0" Margin="5,-1,5,0" Name="TextBoxDiamChaine1" Text="0 mm" Foreground="Blue" TextAlignment="Center" VerticalAlignment="Top" IsReadOnly="True" />
                    <TextBox Grid.Row="2" Grid.Column="0" Margin="5,0,5,3" Name="TextBoxDiamChaine2" Text="" Foreground="Green" TextAlignment="Center" VerticalAlignment="Bottom" IsReadOnly="True" />

                    <TextBlock Grid.Row="0" Grid.Column="1" Name="ResultTextBlockType" Text="Type" TextAlignment="Center" />
                    <TextBox Grid.Row="1" Grid.Column="1" Margin="5,-1,5,0" Name="TextBoxTypeChaine1" Text="" Foreground="Blue" TextAlignment="Center" VerticalAlignment="Top" IsReadOnly="True" />
                    <TextBox Grid.Row="2" Grid.Column="1" Margin="5,0,5,3" Name="TextBoxTypeChaine2" Text="" Foreground="Green" TextAlignment="Center" VerticalAlignment="Bottom" IsReadOnly="True" />

                    <TextBlock Grid.Row="0" Grid.Column="2" Name="ResultTextBlockLest" Text="Lest" TextAlignment="Center" />
                    <TextBox Grid.Row="1" Grid.Column="2" Margin="5,-1,5,0" Name="TextBoxLest1" Text="" Foreground="Blue" TextAlignment="Center" VerticalAlignment="Top" IsReadOnly="True" />
                    <TextBox Grid.Row="2" Grid.Column="2" Margin="5,0,5,3" Name="TextBoxLest2" Text="" Foreground="Green" TextAlignment="Center" VerticalAlignment="Bottom" IsReadOnly="True" />

                    <TextBlock Grid.Row="0" Grid.Column="3" Name="ResultTextBlockDensite" Text="Densité" TextAlignment="Center" />
                    <TextBox Grid.Row="1" Grid.Column="3" Margin="5,-1,5,0" Name="TextBoxDensiteCM1" Text="" Foreground="Blue" TextAlignment="Center" VerticalAlignment="Top" IsReadOnly="True" />
					<TextBox Grid.Row="2" Grid.Column="3" Margin="5,0,5,3" Name="TextBoxDensiteCM2" Text="" Foreground="Green" TextAlignment="Center" VerticalAlignment="Bottom" IsReadOnly="True" />

					<Border Grid.Row="0" Grid.RowSpan="4" Grid.Column="4" Margin="0,5,0,5" Background="Gray" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" />
						
					<StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="5">
                        <TextBlock Name="ResultTextBlockProfondeur" Text="Profondeur" TextAlignment="Center" VerticalAlignment="Center" />
                        <TextBox Margin="5,0,5,0" Name="TextBoxProfondeur" Text="0 m" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" KeyUp="TextBoxProfondeur_KeyUp" />
                        <TextBlock Name="ResultTextBlockMasseEquipement" Text="Masse équipements" TextAlignment="Center" VerticalAlignment="Center" />
                        <TextBox Margin="5,0,5,0" Name="TextBoxMassEquipement" Text="0 kg" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
                    </StackPanel>

					<StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="6">
                        <TextBlock Name="ResultTextBlockHtMaxVagues" Text="Haut. Maxi. vagues" TextAlignment="Center" VerticalAlignment="Center" />
						<TextBox Margin="5,0,5,0" Name="TextBoxHtMaxVague" Text="0 m" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
                        <TextBlock Name="ResultTextBlockHtSignifVague" Text="Haut. Signif. vagues" TextAlignment="Center" VerticalAlignment="Center" />
						<TextBox Margin="5,0,5,0" Name="TextBoxHtSignifVague" Text="0 m" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
					</StackPanel>

					<StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="7">
                        <TextBlock Name="ResultTextBlockPeriodeVague" Text="Période vagues" TextAlignment="Center" VerticalAlignment="Center" />
						<TextBox Margin="5,0,5,0" Name="TextBoxPeriodeVague" Text="0 s" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
                        <TextBlock Name="ResultTextBlockMarnage" Text="Marnage" TextAlignment="Center" VerticalAlignment="Center" />
                        <TextBox Margin="5,0,5,0" Name="TextBoxMarnage" Text="0 m" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
                    </StackPanel>
					
					<StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="8">
                        <TextBlock Name="ResultTextBlockVitVentMS" Text="Vit. Max. vent" TextAlignment="Center" VerticalAlignment="Center" />
						<TextBox Margin="5,0,5,0" Name="TextBoxVitMaxVentms" Text="0 m/s" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
                        <TextBlock Name="ResultTextBlockVitVentKMH" Text="Vit. Max. vent" TextAlignment="Center" VerticalAlignment="Center" />
						<TextBox Margin="5,0,5,0" Name="TextBoxVitMaxVentkmh" Text="0 km/h" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
					</StackPanel>

                    <StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="9">
                        <TextBlock Name="ResultTextBlockVitCourantMS" Text="Vit. Max. courant" TextAlignment="Center" VerticalAlignment="Center" />
                        <TextBox Margin="5,0,5,0" Name="TextBoxVitMaxCms" Text="0 m/s" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
                        <TextBlock Name="ResultTextBlockVitCourantNds" Text="Vit. Max. courant" TextAlignment="Center" VerticalAlignment="Center" />
						<TextBox Margin="5,0,5,0" Name="TextBoxVitMaxCnds" Text="0 nds" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
					</StackPanel>

                    <Border Grid.Row="0" Grid.RowSpan="4" Grid.Column="10" Margin="0,5,0,5" Background="Gray" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" />
                    <StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="11">
                        <TextBlock Name="ResultTextBlockDensiteEau" Text="Densité eau" TextAlignment="Center" VerticalAlignment="Center" />
                        <TextBox Margin="5,0,5,0" Name="TextBoxDensiteEau" Text="1.025" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
                        <TextBlock Name="ResultTextBlockCoefTrainee" Text="Trainée coef." TextAlignment="Center" VerticalAlignment="Center" />
                        <TextBox Margin="5,0,5,0" Name="TextBoxCoefTrainee" Text="1.2" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
                    </StackPanel>

                    <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" Name="ResultTextBlockParametreChaineCM" Text="Paramètres de la chaîne et du corps mort saisis" TextAlignment="Center" Foreground="Gray" />
                    <TextBlock Grid.Row="3" Grid.Column="5" Grid.ColumnSpan="5" Name="ResultTextBlockConditionSiteSaisi" Text="Conditions de site saisies" TextAlignment="Center" Foreground="Gray" />
                    <TextBlock Grid.Row="3" Grid.Column="11" Grid.ColumnSpan="5" Name="ResultTextBlockAvances" Text="Avancés" TextAlignment="Center" Foreground="Gray" />
                </Grid>
					
			</Border>

			<Border Grid.Row="1" BorderThickness="1,0,1,1" CornerRadius="0,0,5,5" BorderBrush="Black">
                <Grid>
					<Grid.RowDefinitions>
						<RowDefinition />
						<RowDefinition Height="20" />
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
						<ColumnDefinition Width="1" />
						<ColumnDefinition />
					</Grid.ColumnDefinitions>

                    <Grid Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
							<ColumnDefinition />
							<ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.ColumnSpan="2" Name="ResultTextBlockProfondeurResultat" Text="Profondeur" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Top" HorizontalAlignment="Center" />
                        
                        <StackPanel Grid.Column="0" Margin="0,15,0,0">
                            <Grid Margin="5,1,5,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Margin="2,0,2,0" Name="ResultTextBlockProfMin" Text="Minimale" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Margin="2,0,2,0" Name="TextBoxProfMin" Text="0.0 m" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
                            </Grid>

                            <TextBlock Name="ResultTextBlockLongueurCat" Text="Longueur caténaire" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" />
                            <Grid Margin="5,1,5,0">
								<Grid.ColumnDefinitions>
									<ColumnDefinition />
									<ColumnDefinition />
								</Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Margin="2,0,2,0" Name="TextBoxLongueurCat1" Foreground="Blue" Text="0.0 m" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
                                <TextBox Grid.Column="1" Margin="2,0,2,0" Name="TextBoxLongueurCat2" Foreground="Green" Text="0.0 m" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
							</Grid>

                            <TextBlock Name="ResultTextBlockTensionMax" Text="Tension maximale" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" />
                            <TextBlock Name="ResultTextBlockMouillage" Text="mouillage" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" />
                            <Grid Margin="5,1,5,0">
								<Grid.ColumnDefinitions>
									<ColumnDefinition />
									<ColumnDefinition />
								</Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Margin="2,0,2,0" Name="TextBoxTensionMaxMouillage1" Foreground="Blue" Text="0.0 t" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
                                <TextBox Grid.Column="1" Margin="2,0,2,0" Name="TextBoxTensionMaxMouillage2" Foreground="Green" Text="0.0 t" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
							</Grid>

                            <TextBlock Name="ResultTextBlockMasseMinCM" Text="Masse minimale corps mort" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" />
                            <Grid Margin="5,1,5,0">
								<Grid.ColumnDefinitions>
									<ColumnDefinition />
									<ColumnDefinition />
								</Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Margin="2,0,2,0" Name="TextBoxMasseMinCM1" Text="0.0 t" Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
                                <TextBox Grid.Column="1" Margin="2,0,2,0" Name="TextBoxMasseMinCM2" Text="0.0 t" Foreground="Green" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
							</Grid>

                            <TextBlock Name="ResultTextBlockReserveFlota" Text="Réserve flottabilité bouée" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" />
                            <Grid Margin="5,1,5,0">
								<Grid.ColumnDefinitions>
									<ColumnDefinition />
									<ColumnDefinition />
								</Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Margin="2,0,2,0" Name="TextBoxReserveFlota1" Text="0 %" Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
                                <TextBox Grid.Column="1" Margin="2,0,2,0" Name="TextBoxReserveFlota2" Text="0 %" Foreground="Green" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
							</Grid>

                            <TextBlock Name="ResultTextBlockFrancBord" Text="Franc bord bouée" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" />
                            <Grid Margin="5,1,5,0">
								<Grid.ColumnDefinitions>
									<ColumnDefinition />
									<ColumnDefinition />
								</Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Margin="2,0,2,0" Name="TextBoxFrancBord1" Text="0.00 m" Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
                                <TextBox Grid.Column="1" Margin="2,0,2,0" Name="TextBoxFrancBord2" Text="0.00 m" Foreground="Green" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
							</Grid>

                            <TextBlock Name="ResultTextBlockSurfLatImme" Text="Surface latérale immergée" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" />
                            <Grid Margin="5,1,5,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Margin="2,0,2,0" Name="TextBoxSurfaceLateraleImmergee1" Foreground="Blue" Text="0.0 m²" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
                                <TextBox Grid.Column="1" Margin="2,0,2,0" Name="TextBoxSurfaceLateraleImmergee2" Foreground="Green" Text="0.0 m²" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,15,0,0">

                            <Grid Margin="5,1,5,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Margin="2,0,2,0" Name="ResultTextBlockProfMax" Text="Maximale" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Margin="2,0,2,0" Name="TextBoxProfMax" Text="0.0 m" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
                            </Grid>

                            <TextBlock Name="ResultTextBlockRayonEvitage" Text="Rayon d'évitage maximal" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" />
                            <Grid Margin="5,1,5,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Margin="2,0,2,0" Name="TextBoxRayonEvitage1" Text="0.0 m" Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
                                <TextBox Grid.Column="1" Margin="2,0,2,0" Name="TextBoxRayonEvitage2" Text="0.0 m" Foreground="Green" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
                            </Grid>

                            <TextBlock Name="ResultTextBlockCoefSecuChaine" Text="Coef. sécurité chaîne" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" />
                            <TextBlock Name="ResultTextBlockIALACoefSecu" Text="(IALA: ≥5\\Ce)" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" />
                            <Grid Margin="5,1,5,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Margin="2,0,2,0" Name="TextBoxCoefSecuriteChaine1" Text="0.0" Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
                                <TextBox Grid.Column="1" Margin="2,0,2,0" Name="TextBoxCoefSecuriteChaine2" Text="0.0" Foreground="Green" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
                            </Grid>

                            <TextBlock Name="ResultTextBlockTraineH" Text="Trainée horizontale" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" />
                            <Grid Margin="5,1,5,0">
								<Grid.ColumnDefinitions>
									<ColumnDefinition />
									<ColumnDefinition />
								</Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Margin="2,0,2,0" Name="TextBoxTraineeHorizontale1" Text="0.0 t" Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" />
